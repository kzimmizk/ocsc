---
interface Props {
  name: string;
  role: string;
  email?: string;
  photo?: string;
  /** Rendered bio HTML (optional). */
  bioHtml?: string;
}

const { name, role, email, photo } = Astro.props;
const initials = name
  .split(' ')
  .map((p) => p[0])
  .slice(0, 2)
  .join('');
---

<article class="card">
  <div class="card__avatar" aria-hidden={photo ? undefined : 'true'}>
    {
      photo ? (
        <img src={`/board/${photo}`} alt={name} width="96" height="96" />
      ) : (
        <span class="card__initials">{initials}</span>
      )
    }
  </div>
  <h3 class="card__name">{name}</h3>
  <p class="card__role">{role}</p>
  {
    email && (
      <a class="card__email" href={`mailto:${email}`}>
        {email}
      </a>
    )
  }
  <div class="card__bio">
    <slot />
  </div>
</article>

<style>
  .card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.5rem;
    text-align: center;
  }
  .card__avatar {
    width: 96px;
    height: 96px;
    margin: 0 auto 1rem;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-primary);
    color: var(--color-on-primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card__initials {
    font-size: 2rem;
    font-weight: 800;
  }
  .card__name {
    margin: 0 0 0.15rem;
    font-size: 1.2rem;
  }
  .card__role {
    margin: 0 0 0.5rem;
    color: var(--color-muted);
    font-weight: 600;
  }
  .card__email {
    font-size: 0.95rem;
    word-break: break-word;
  }
  .card__bio {
    margin-top: 0.5rem;
    font-size: 0.95rem;
    color: var(--color-muted);
  }
  .card__bio :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
