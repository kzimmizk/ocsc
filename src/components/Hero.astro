---
interface Props {
  headline: string;
  tagline: string;
  registerUrl: string;
}

const { headline, tagline, registerUrl } = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <p class="hero__tagline">{tagline}</p>
    <h1 class="hero__headline">{headline}</h1>
    <div class="hero__actions">
      <a class="btn btn--primary" href={registerUrl} rel="noopener">Register Now</a>
      <a class="btn btn--ghost" href="/about/">Learn More</a>
    </div>
  </div>
</section>

<style>
  .hero {
    /* Club photo with a left-weighted navy overlay so text stays legible.
       To swap the photo, replace public/hero.jpg. */
    background:
      linear-gradient(
        90deg,
        rgba(6, 27, 56, 0.92) 0%,
        rgba(6, 27, 56, 0.66) 45%,
        rgba(10, 42, 82, 0.4) 100%
      ),
      url('/hero.jpg') center 38% / cover no-repeat;
    color: var(--color-on-primary);
    display: flex;
    align-items: center;
    min-height: clamp(420px, 60vh, 620px);
  }
  .hero__inner {
    padding-block: clamp(2.5rem, 7vw, 4.5rem);
    max-width: 60ch;
  }
  .hero__tagline {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.4);
  }
  .hero__headline {
    color: var(--color-on-primary);
    margin-bottom: 1.5rem;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.4);
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }
</style>
