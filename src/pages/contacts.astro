---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getEntry } from 'astro:content';

const settings = await getEntry('settings', 'site');
if (!settings) throw new Error('Missing settings/site.yaml');
const site = settings.data;
---

<BaseLayout
  title="Contacts"
  description="Get in touch with the Ouray County Soccer Club."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Get in Touch</p>
      <h1>Contact Us</h1>
      <p class="section__intro">
        The club is run by volunteers. For questions about registration,
        sponsorship, or coaching, send us an email and we'll get back to you.
      </p>

      <div class="contact-card">
        <p class="contact-card__club">{site.clubName}</p>
        {
          site.contactEmail && (
            <a class="contact-card__email" href={`mailto:${site.contactEmail}`}>
              {site.contactEmail}
            </a>
          )
        }
        {site.location && <p class="contact-card__line">{site.location}</p>}
        {
          site.mailingAddress && (
            <p class="contact-card__line">{site.mailingAddress}</p>
          )
        }
        {
          site.social && (site.social.facebook || site.social.instagram) && (
            <div class="contact-card__social">
              <SocialLinks
                facebook={site.social.facebook}
                instagram={site.social.instagram}
              />
            </div>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-card {
    margin-top: 1.5rem;
    max-width: 480px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.75rem;
  }
  .contact-card__club {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    font-weight: 800;
  }
  .contact-card__email {
    font-size: 1.05rem;
    font-weight: 600;
    word-break: break-word;
  }
  .contact-card__line {
    margin: 0.5rem 0 0;
    color: var(--color-muted);
  }
  .contact-card__social {
    margin-top: 1rem;
  }
</style>
